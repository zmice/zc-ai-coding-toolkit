{
  "name": "@zmice/zc",
  "version": "0.1.2",
  "description": "Operator/runtime CLI for the AI Coding Toolkit workspace",
  "keywords": ["cli", "orchestration", "tmux", "team", "ai", "codex", "multi-agent"],
  "license": "MIT",
  "type": "module",
  "bin": {
    "zc": "./dist/cli/index.js"
  },
  "files": [
    "dist",
    "README.md"
  ],
  "scripts": {
    "build": "tsc",
    "dev": "tsc --watch",
    "test": "vitest run",
    "lint": "tsc --noEmit",
    "generate": "pnpm build",
    "verify": "pnpm test && pnpm build",
    "prepublishOnly": "pnpm lint && pnpm test && pnpm build"
  },
  "dependencies": {
    "@zmice/platform-core": "workspace:*",
    "@zmice/platform-codex": "workspace:*",
    "@zmice/platform-qoder": "workspace:*",
    "@zmice/platform-qwen": "workspace:*",
    "@zmice/toolkit": "workspace:*",
    "commander": "^13.0.0"
  },
  "devDependencies": {
    "typescript": "^5.7.0",
    "@types/node": "^22.0.0",
    "vitest": "^3.0.0"
  },
  "engines": {
    "node": ">=20.0.0"
  }
}
