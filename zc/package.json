{
  "name": "@zmice/zc",
  "version": "0.1.2",
  "description": "Orchestrate multiple AI CLI tools (Codex, Qwen Code, etc.) as a collaborative team — parallel task dispatch, skill matching, git worktree isolation, and inter-agent messaging",
  "keywords": ["cli", "orchestration", "tmux", "team", "ai", "codex", "multi-agent"],
  "license": "MIT",
  "type": "module",
  "bin": {
    "zc": "./dist/cli/index.js"
  },
  "files": [
    "dist",
    "!dist/**/__tests__",
    "!dist/**/*.test.*",
    "README.md",
    "LICENSE"
  ],
  "scripts": {
    "build": "tsc",
    "dev": "tsc --watch",
    "test": "vitest",
    "lint": "tsc --noEmit",
    "prepublishOnly": "npm run lint && npm run test -- --run && npm run build"
  },
  "dependencies": {
    "commander": "^13.0.0"
  },
  "devDependencies": {
    "typescript": "^5.7.0",
    "@types/node": "^22.0.0",
    "vitest": "^3.0.0"
  },
  "engines": {
    "node": ">=20.0.0"
  }
}
