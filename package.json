{
  "name": "ai-coding-toolkit-workspace",
  "private": true,
  "packageManager": "pnpm@10.13.1",
  "scripts": {
    "dev": "pnpm --dir apps/cli dev",
    "lint": "node scripts/run-workspace-task.mjs lint",
    "test": "node scripts/run-workspace-task.mjs test",
    "build": "node scripts/run-workspace-task.mjs build",
    "generate": "node scripts/run-workspace-task.mjs generate",
    "verify": "node scripts/run-workspace-task.mjs verify",
    "verify:mvp": "node scripts/verify-workspace.mjs",
    "upstream": "node scripts/upstream-governance.mjs",
    "changeset": "changeset",
    "release:check": "node scripts/release-check.mjs pre-version",
    "release:check:post-version": "node scripts/release-check.mjs post-version",
    "release": "changeset publish"
  },
  "devDependencies": {
    "@changesets/cli": "^2.29.4"
  }
}
